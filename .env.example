# Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_TOKEN=

# Credenciales de OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ID de la Google Sheet donde se loguean los leads
GOOGLE_SHEET_ID=

# En local: ruta al archivo de credenciales de la service account
# En producción (Railway): no usar esto, usar GOOGLE_CREDENTIALS_JSON con el contenido del JSON
GOOGLE_CREDENTIALS_PATH=credentials.json
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
